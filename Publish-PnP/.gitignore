# 从主仓库拉取的源码副本 — 由 launcher.exe 自动下载,不入库
app/
config/
pyproject.toml
setup.py
setup_c.py
build_rust.py
requirements-bundle.txt
CHANGELOG.md
README_MAIN.md
tests/

