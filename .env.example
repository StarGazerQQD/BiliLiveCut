# ===========================================================================
# BiliLiveCut 配置模板
# 复制为 .env 后填写。切勿把真实密钥提交到版本库(.env 已被 .gitignore 忽略)。
# 所有变量都有合理默认值;MVP 阶段通常只需关注 STORAGE_ROOT 与 FFMPEG_PATH。
# ===========================================================================

# ---------- 通用 ----------
# 运行环境:dev / prod。影响日志级别与一些默认行为。
APP_ENV=dev
# 日志级别:DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ---------- 存储 ----------
# 所有运行产物(原始片段、切片、日志、数据库)的根目录。
STORAGE_ROOT=./storage
# SQLite 数据库文件路径(相对 STORAGE_ROOT 或绝对路径)。
DATABASE_URL=sqlite:///./storage/blc.db

# ---------- FFmpeg ----------
# FFmpeg / ffprobe 可执行文件路径。已加入 PATH 时填命令名即可。
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# ---------- 录制 / 分片 ----------
# 单个原始片段时长(秒)。可选 30 / 60 / 120。
SEGMENT_DURATION_S=60
# 取流优先协议:hls 或 flv。hls 更稳、更易精确分片。
PREFERRED_STREAM_PROTOCOL=hls
# 期望清晰度码(qn):10000=原画, 400=蓝光, 250=超清, 150=高清, 80=流畅。
STREAM_QUALITY=10000
# 断流重连最大退避秒数。
RECONNECT_MAX_BACKOFF_S=30
# 直播开播状态轮询间隔(秒)。请勿设置过小以免对平台造成压力。
LIVE_POLL_INTERVAL_S=15
# 录制期间是否同时采集弹幕(用于弹幕热度与高光评分的弹幕维度)。
COLLECT_DANMAKU=true

# ---------- 网感资料库(联网采集高热度内容,供高光评分与文案参考) ----------
# 启用后会用具备联网搜索能力的模型采集近期热门话题/标题/标签并入库。
TREND_ENABLED=false
# 趋势采集专用 API(独立于通用 LLM,可指定不同模型/服务商)。留空则复用通用 LLM 配置。
TREND_API_KEY=
TREND_BASE_URL=
# 趋势采集专用模型名(留空则复用 LLM_MODEL)。
TREND_MODEL=
# 是否启用模型的联网搜索工具(关闭则仅依赖模型已有知识,时效性较差)。
TREND_WEB_SEARCH=true
# 单次采集允许的联网搜索次数上限(控制成本)。
TREND_MAX_SEARCHES=5
# 单次采集解析入库的条目数量上限。
TREND_MAX_ITEMS=40
# 资料库保留天数(超期数据可被清理)。
TREND_RETENTION_DAYS=14
# 高光评分/文案参考时,视为"近期"的时间窗口(天)。
TREND_MATCH_DAYS=7

# ---------- Bilibili 合规 ----------
# 仅录制你有权录制的内容。设为 true 表示你已确认拥有相应授权。
REQUIRE_AUTHORIZATION=true
# 可选:登录态 cookie(用于更高清晰度或弹幕鉴权)。留空则匿名访问公开信息。
# 风险:携带 cookie 的自动化行为可能触发平台风控,请自行评估。
BILIBILI_COOKIE=

# ---------- AI:语音转写(本地 Whisper,境内可用,无需联网) ----------
# 转写模型:tiny / base / small / medium / large-v3。MVP 建议 small。
WHISPER_MODEL=small
# 计算设备:cpu 或 cuda。
WHISPER_DEVICE=cpu
# 计算精度:int8(CPU 推荐) / float16(GPU)。
WHISPER_COMPUTE_TYPE=int8

# ---------- AI:大模型(OpenAI 兼容协议,境内推荐 DeepSeek/通义/Kimi/GLM) ----------
# 系统主要在中国大陆运行,故采用 OpenAI 兼容协议对接境内可稳定访问的服务商。
# 只需配置以下三项即可切换服务商;切勿把真实密钥提交到版本库。
LLM_PROVIDER=deepseek
LLM_API_KEY=
# base_url 按服务商填写(须含版本前缀):
#   DeepSeek : https://api.deepseek.com/v1            模型示例:deepseek-chat
#   通义千问 : https://dashscope.aliyuncs.com/compatible-mode/v1   模型:qwen-plus / qwen-max
#   Kimi     : https://api.moonshot.cn/v1             模型:moonshot-v1-8k
#   智谱 GLM  : https://open.bigmodel.cn/api/paas/v4   模型:glm-4-plus
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
# 联网搜索开关键名(以 extra_body 传入)。通义/Kimi/GLM 多用 enable_search;
# DeepSeek 等不支持则会自动回退为普通调用。留空表示不尝试联网搜索参数。
LLM_WEB_SEARCH_PARAM=enable_search
# 成本护栏:每百万 token 价格(币种随你填,建议用人民币元)。设 0 表示不计费、不限额。
LLM_PRICE_INPUT_PER_M=0
LLM_PRICE_OUTPUT_PER_M=0
# LLM 每日成本上限(与上面价格同币种),超出后自动降级为纯规则模式。0 表示不限制。
LLM_DAILY_BUDGET=0

# ---------- 高光判断阈值 ----------
# 进入 LLM 复核的初筛阈值(0-1)。
HIGHLIGHT_INIT_THRESHOLD=0.5
# 进入候选池的综合评分阈值(0-1)。
HIGHLIGHT_THRESHOLD=0.65
# 全自动模式下直接发布的阈值(0-1)。
AUTO_PUBLISH_THRESHOLD=0.85

# ---------- 切片后处理(阶段3) ----------
# 响度标准化(EBU R128,推荐开启,统一音量)。
CLIP_LOUDNORM=true
# 去除切片首尾静默段。
CLIP_REMOVE_SILENCE=false
# 竖屏重构为 1080x1920(居中 + 黑边),适合手机端短视频。
CLIP_VERTICAL=false
# 烧录字幕(从转写生成 SRT 并压制)。Windows 下路径转义较繁琐,默认关闭。
CLIP_SUBTITLE=false
# 单个切片最大时长(秒),超出会被截断。
CLIP_MAX_DURATION_S=180
# x264 画质(CRF,0-51,越小越清晰、文件越大)与编码速度档。
CLIP_VIDEO_CRF=20
CLIP_PRESET=veryfast

# ---------- 上传(阶段5,默认 manual,零风险) ----------
# 默认上传器:manual(仅产出成品+元数据,不调用平台接口)。
# 是否启用 biliup 由 Web 后台的开关控制(运行时持久化于数据库),不在此写死。
UPLOADER=manual
# 上传失败最大重试次数。
UPLOAD_MAX_RETRIES=3
# 投稿频率上限(每小时成功上传数),超过则新任务被跳过(频控)。
UPLOAD_MAX_PER_HOUR=5
# 标题/简介长度上限(合规预检)。
TITLE_MAX_LEN=80
DESC_MAX_LEN=2000

# --- biliup(社区方案,合规风险自负;默认不启用) ---
# 说明:Bilibili 无面向普通用户的官方公开投稿 API。biliup 等社区工具使用你自己的
# 登录态 cookie 走网页投稿端点,可能违反平台条款、触发风控甚至封号,且接口随时变更。
# 仅在你充分理解并接受风险后,于 Web 后台开启开关并配置以下项。
# biliup 凭据/配置文件路径(如 biliup-rs 的 cookies.json / config.toml)。
BILIUP_CONFIG=
# 自定义上传命令模板,支持占位符 {file} {title} {desc}。留空则 biliup 上传会安全失败。
# 例: BILIUP_UPLOAD_CMD=biliup upload "{file}" --title "{title}"
BILIUP_UPLOAD_CMD=
