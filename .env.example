# ===========================================================================
# BiliLiveCut 閰嶇疆妯℃澘
# 澶嶅埗涓?.env 鍚庡～鍐欍€傚垏鍕挎妸鐪熷疄瀵嗛挜鎻愪氦鍒扮増鏈簱(.env 宸茶 .gitignore 蹇界暐)銆?
# 鎵€鏈夊彉閲忛兘鏈夊悎鐞嗛粯璁ゅ€?MVP 闃舵閫氬父鍙渶鍏虫敞 STORAGE_ROOT 涓?FFMPEG_PATH銆?
# ===========================================================================

# ---------- 閫氱敤 ----------
# 杩愯鐜:dev / prod銆傚奖鍝嶆棩蹇楃骇鍒笌涓€浜涢粯璁よ涓恒€?
APP_ENV=dev
# 鏃ュ織绾у埆:DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ---------- pip 闀滃儚(涓浗澶ч檰鍔犻€? ----------
# 榛樿浣跨敤闃块噷浜?PyPI 闀滃儚,娓呭崕浣滀负澶囩敤銆傚彲閫氳繃鐜鍙橀噺瑕嗙洊,鐣欑┖浣跨敤榛樿鍊笺€?
PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
PIP_EXTRA_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple

# ---------- 瀛樺偍 ----------
# 鎵€鏈夎繍琛屼骇鐗?鍘熷鐗囨銆佸垏鐗囥€佹棩蹇椼€佹暟鎹簱)鐨勬牴鐩綍銆?
STORAGE_ROOT=./storage
# SQLite 鏁版嵁搴撴枃浠惰矾寰?鐩稿 STORAGE_ROOT 鎴栫粷瀵硅矾寰?銆?
DATABASE_URL=sqlite:///./storage/blc.db

# ---------- FFmpeg ----------
# FFmpeg / ffprobe 鍙墽琛屾枃浠惰矾寰勩€傚凡鍔犲叆 PATH 鏃跺～鍛戒护鍚嶅嵆鍙€?
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# ---------- 褰曞埗 / 鍒嗙墖 ----------
# 鍗曚釜鍘熷鐗囨鏃堕暱(绉?銆傚彲閫?30 / 60 / 120銆?
SEGMENT_DURATION_S=60
# 鍙栨祦浼樺厛鍗忚:hls 鎴?flv銆俬ls 鏇寸ǔ銆佹洿鏄撶簿纭垎鐗囥€?
PREFERRED_STREAM_PROTOCOL=hls
# 鏈熸湜娓呮櫚搴︾爜(qn):10000=鍘熺敾, 400=钃濆厜, 250=瓒呮竻, 150=楂樻竻, 80=娴佺晠銆?
STREAM_QUALITY=10000
# 鏂祦閲嶈繛鏈€澶ч€€閬跨鏁般€?
RECONNECT_MAX_BACKOFF_S=30
# 鐩存挱寮€鎾姸鎬佽疆璇㈤棿闅?绉?銆傝鍕胯缃繃灏忎互鍏嶅骞冲彴閫犳垚鍘嬪姏銆?
LIVE_POLL_INTERVAL_S=15
# 褰曞埗鏈熼棿鏄惁鍚屾椂閲囬泦寮瑰箷(鐢ㄤ簬寮瑰箷鐑害涓庨珮鍏夎瘎鍒嗙殑寮瑰箷缁村害)銆?
COLLECT_DANMAKU=true

# ---------- 缃戞劅璧勬枡搴?鑱旂綉閲囬泦楂樼儹搴﹀唴瀹?渚涢珮鍏夎瘎鍒嗕笌鏂囨鍙傝€? ----------
# 鍚敤鍚庝細鐢ㄥ叿澶囪仈缃戞悳绱㈣兘鍔涚殑妯″瀷閲囬泦杩戞湡鐑棬璇濋/鏍囬/鏍囩骞跺叆搴撱€?
TREND_ENABLED=false
# 瓒嬪娍閲囬泦涓撶敤 API(鐙珛浜庨€氱敤 LLM,鍙寚瀹氫笉鍚屾ā鍨?鏈嶅姟鍟?銆傜暀绌哄垯澶嶇敤閫氱敤 LLM 閰嶇疆銆?
TREND_API_KEY=
TREND_BASE_URL=
# 瓒嬪娍閲囬泦涓撶敤妯″瀷鍚?鐣欑┖鍒欏鐢?LLM_MODEL)銆?
TREND_MODEL=
# 鏄惁鍚敤妯″瀷鐨勮仈缃戞悳绱㈠伐鍏?鍏抽棴鍒欎粎渚濊禆妯″瀷宸叉湁鐭ヨ瘑,鏃舵晥鎬ц緝宸?銆?
TREND_WEB_SEARCH=true
# 鍗曟閲囬泦鍏佽鐨勮仈缃戞悳绱㈡鏁颁笂闄?鎺у埗鎴愭湰)銆?
TREND_MAX_SEARCHES=5
# 鍗曟閲囬泦瑙ｆ瀽鍏ュ簱鐨勬潯鐩暟閲忎笂闄愩€?
TREND_MAX_ITEMS=40
# 璧勬枡搴撲繚鐣欏ぉ鏁?瓒呮湡鏁版嵁鍙娓呯悊)銆?
TREND_RETENTION_DAYS=14
# 楂樺厜璇勫垎/鏂囨鍙傝€冩椂,瑙嗕负"杩戞湡"鐨勬椂闂寸獥鍙?澶?銆?
TREND_MATCH_DAYS=7

# ---------- Bilibili 鍚堣 ----------
# 浠呭綍鍒朵綘鏈夋潈褰曞埗鐨勫唴瀹广€傝涓?true 琛ㄧず浣犲凡纭鎷ユ湁鐩稿簲鎺堟潈銆?
REQUIRE_AUTHORIZATION=true
# 鍙€?鐧诲綍鎬?cookie(鐢ㄤ簬鏇撮珮娓呮櫚搴︽垨寮瑰箷閴存潈)銆傜暀绌哄垯鍖垮悕璁块棶鍏紑淇℃伅銆?
# 椋庨櫓:鎼哄甫 cookie 鐨勮嚜鍔ㄥ寲琛屼负鍙兘瑙﹀彂骞冲彴椋庢帶,璇疯嚜琛岃瘎浼般€?
BILIBILI_COOKIE=

# ---------- AI:璇煶杞啓(鏈湴 Whisper,澧冨唴鍙敤,鏃犻渶鑱旂綉) ----------
# 杞啓妯″瀷:tiny / base / small / medium / large-v3銆侻VP 寤鸿 small銆?
WHISPER_MODEL=small
# 璁＄畻璁惧:cpu 鎴?cuda銆?
WHISPER_DEVICE=cpu
# 璁＄畻绮惧害:int8(CPU 鎺ㄨ崘) / float16(GPU)銆?
WHISPER_COMPUTE_TYPE=int8

# ---------- AI:澶фā鍨?OpenAI 鍏煎鍗忚,澧冨唴鎺ㄨ崘 DeepSeek/閫氫箟/Kimi/GLM) ----------
# 绯荤粺涓昏鍦ㄤ腑鍥藉ぇ闄嗚繍琛?鏁呴噰鐢?OpenAI 鍏煎鍗忚瀵规帴澧冨唴鍙ǔ瀹氳闂殑鏈嶅姟鍟嗐€?
# 鍙渶閰嶇疆浠ヤ笅涓夐」鍗冲彲鍒囨崲鏈嶅姟鍟?鍒囧嬁鎶婄湡瀹炲瘑閽ユ彁浜ゅ埌鐗堟湰搴撱€?
LLM_PROVIDER=deepseek
LLM_API_KEY=
# base_url 鎸夋湇鍔″晢濉啓(椤诲惈鐗堟湰鍓嶇紑):
#   DeepSeek : https://api.deepseek.com/v1            妯″瀷绀轰緥:deepseek-chat
#   閫氫箟鍗冮棶 : https://dashscope.aliyuncs.com/compatible-mode/v1   妯″瀷:qwen-plus / qwen-max
#   Kimi     : https://api.moonshot.cn/v1             妯″瀷:moonshot-v1-8k
#   鏅鸿氨 GLM  : https://open.bigmodel.cn/api/paas/v4   妯″瀷:glm-4-plus
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
# 鑱旂綉鎼滅储寮€鍏抽敭鍚?浠?extra_body 浼犲叆)銆傞€氫箟/Kimi/GLM 澶氱敤 enable_search;
# DeepSeek 绛変笉鏀寔鍒欎細鑷姩鍥為€€涓烘櫘閫氳皟鐢ㄣ€傜暀绌鸿〃绀轰笉灏濊瘯鑱旂綉鎼滅储鍙傛暟銆?
LLM_WEB_SEARCH_PARAM=enable_search
# 鎴愭湰鎶ゆ爮:姣忕櫨涓?token 浠锋牸(甯佺闅忎綘濉?寤鸿鐢ㄤ汉姘戝竵鍏?銆傝 0 琛ㄧず涓嶈璐广€佷笉闄愰銆?
LLM_PRICE_INPUT_PER_M=0
LLM_PRICE_OUTPUT_PER_M=0
# LLM 姣忔棩鎴愭湰涓婇檺(涓庝笂闈环鏍煎悓甯佺),瓒呭嚭鍚庤嚜鍔ㄩ檷绾т负绾鍒欐ā寮忋€? 琛ㄧず涓嶉檺鍒躲€?
LLM_DAILY_BUDGET=0

# ---------- 楂樺厜鍒ゆ柇闃堝€?----------
# 杩涘叆 LLM 澶嶆牳鐨勫垵绛涢槇鍊?0-1)銆?
HIGHLIGHT_INIT_THRESHOLD=0.5
# 杩涘叆鍊欓€夋睜鐨勭患鍚堣瘎鍒嗛槇鍊?0-1)銆?
HIGHLIGHT_THRESHOLD=0.65
# 鍏ㄨ嚜鍔ㄦā寮忎笅鐩存帴鍙戝竷鐨勯槇鍊?0-1)銆?
AUTO_PUBLISH_THRESHOLD=0.85

# ---------- 鍒囩墖鍚庡鐞?闃舵3) ----------
# 鍝嶅害鏍囧噯鍖?EBU R128,鎺ㄨ崘寮€鍚?缁熶竴闊抽噺)銆?
CLIP_LOUDNORM=true
# 鍘婚櫎鍒囩墖棣栧熬闈欓粯娈点€?
CLIP_REMOVE_SILENCE=false
# 绔栧睆閲嶆瀯涓?1080x1920(灞呬腑 + 榛戣竟),閫傚悎鎵嬫満绔煭瑙嗛銆?
CLIP_VERTICAL=false
# 鐑у綍瀛楀箷(浠庤浆鍐欑敓鎴?SRT 骞跺帇鍒?銆俉indows 涓嬭矾寰勮浆涔夎緝绻佺悙,榛樿鍏抽棴銆?
CLIP_SUBTITLE=false
# 鍗曚釜鍒囩墖鏈€澶ф椂闀?绉?,瓒呭嚭浼氳鎴柇銆?
CLIP_MAX_DURATION_S=180
# x264 鐢昏川(CRF,0-51,瓒婂皬瓒婃竻鏅般€佹枃浠惰秺澶?涓庣紪鐮侀€熷害妗ｃ€?
CLIP_VIDEO_CRF=20
CLIP_PRESET=veryfast

# ---------- 涓婁紶(闃舵5,榛樿 manual,闆堕闄? ----------
# 榛樿涓婁紶鍣?manual(浠呬骇鍑烘垚鍝?鍏冩暟鎹?涓嶈皟鐢ㄥ钩鍙版帴鍙?銆?
# 鏄惁鍚敤 biliup 鐢?Web 鍚庡彴鐨勫紑鍏虫帶鍒?杩愯鏃舵寔涔呭寲浜庢暟鎹簱),涓嶅湪姝ゅ啓姝汇€?
UPLOADER=manual
# 涓婁紶澶辫触鏈€澶ч噸璇曟鏁般€?
UPLOAD_MAX_RETRIES=3
# 鎶曠棰戠巼涓婇檺(姣忓皬鏃舵垚鍔熶笂浼犳暟),瓒呰繃鍒欐柊浠诲姟琚烦杩?棰戞帶)銆?
UPLOAD_MAX_PER_HOUR=5
# 鏍囬/绠€浠嬮暱搴︿笂闄?鍚堣棰勬)銆?
TITLE_MAX_LEN=80
DESC_MAX_LEN=2000

# --- biliup(绀惧尯鏂规,鍚堣椋庨櫓鑷礋;榛樿涓嶅惎鐢? ---
# 璇存槑:Bilibili 鏃犻潰鍚戞櫘閫氱敤鎴风殑瀹樻柟鍏紑鎶曠 API銆俠iliup 绛夌ぞ鍖哄伐鍏蜂娇鐢ㄤ綘鑷繁鐨?
# 鐧诲綍鎬?cookie 璧扮綉椤垫姇绋跨鐐?鍙兘杩濆弽骞冲彴鏉℃銆佽Е鍙戦鎺х敋鑷冲皝鍙?涓旀帴鍙ｉ殢鏃跺彉鏇淬€?
# 浠呭湪浣犲厖鍒嗙悊瑙ｅ苟鎺ュ彈椋庨櫓鍚?浜?Web 鍚庡彴寮€鍚紑鍏冲苟閰嶇疆浠ヤ笅椤广€?
# biliup 鍑嵁/閰嶇疆鏂囦欢璺緞(濡?biliup-rs 鐨?cookies.json / config.toml)銆?
BILIUP_CONFIG=
# 鑷畾涔変笂浼犲懡浠ゆā鏉?鏀寔鍗犱綅绗?{file} {title} {desc}銆傜暀绌哄垯 biliup 涓婁紶浼氬畨鍏ㄥけ璐ャ€?
# 渚? BILIUP_UPLOAD_CMD=biliup upload "{file}" --title "{title}"
BILIUP_UPLOAD_CMD=

# ---------- V0.1.7 P3:磁盘保护与存储生命周期 ----------
# 最低磁盘剩余空间(GB),低於此值暂缓高风险新任务。
MIN_FREE_DISK_GB=10
# 原始录像保留天数,超时自动清理。
RAW_RETENTION_DAYS=7
# 成片成功后原始分段延迟清理时间(小时)。
CLIP_CLEANUP_DELAY_HOURS=24
