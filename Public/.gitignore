# 即插即用版的重体积/生成产物不入库(由 build_bundle.py 生成或联网下载)。
models/
vendor/
bin/
.venv/
storage/
*.log
__pycache__/
.ruff_cache/

# 源码副本 — 入库,使 git clone 即可用(无需先跑 build_bundle.py)。
# build_bundle.py 仍会在打包时刷新这些文件以保持最新。
# app/ config/ pyproject.toml README_MAIN.md 已从此列表移除,改为入库。

# 体检生成的清单(每次打包/体检自动刷新,不入库)。
manifest.json

# PyInstaller 构建产物(launcher.py/build_exe.py 和输出 launcher.exe 均入库)。
build/
*.spec
